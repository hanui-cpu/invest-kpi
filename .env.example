# Gemini API 키 (Google AI Studio에서 발급)
# 실제 키는 .env 파일에 넣고, .env는 절대 git에 올리지 마세요.
GEMINI_API_KEY=여기에_키를_붙여넣으세요

# 비공개 시트 읽기용 서비스(로봇) 계정 JSON 키 — "한 줄 압축 JSON" 문자열로 넣으세요.
# (Vercel에는 `vercel env add GOOGLE_SERVICE_ACCOUNT_JSON production` 으로 등록)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account", ... 전체_JSON_한줄 ... }
